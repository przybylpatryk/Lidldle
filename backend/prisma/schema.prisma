generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model daily_image {
  product_id Int      @id
  image_date DateTime @db.Date
}

model daily_product {
  product_id   Int      @id
  product_date DateTime @db.Date
}

model image_guesses {
  user_id    Int    @id
  product_id Int
  name       String @db.VarChar(50)
}

model product {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(50)
  brand    String  @db.VarChar(50)
  category String  @db.VarChar(50)
  weight   String  @db.VarChar(30)
  price    Decimal @db.Decimal(10, 2)
}

model product_guesses {
  user_id    Int     @id
  product_id Int
  name       String  @db.VarChar(50)
  brand      String  @db.VarChar(50)
  category   String  @db.VarChar(50)
  weight     String  @db.VarChar(20)
  price      Decimal @db.Decimal(10, 2)
}

model product_image {
  product_id Int    @id
  image_url  String @db.VarChar(50)
}
